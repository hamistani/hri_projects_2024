<launch>

    <!-- complete robot model with base_footprint -->
    <rosparam param="source_list">['joint_state_out']</rosparam>

    <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_commander"/>

    <!-- additionally load the robot state publisher -->
    <node pkg="week4" type="tf_look_at_hand.py" name="look_at_hand" output="screen"/>

    <!-- add the joint mover -->
<!--     <node pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" name="nao_mover"/> -->

</launch>